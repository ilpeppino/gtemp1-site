---
const {
  eyebrow = "Independent software studio",
  titleLines = ["Focused products.", "Clear purpose.", "Built to grow."],
  description = "Gtemp1 builds practical digital products with strong usability and solid technical foundations. Explore the applications we are building today, starting with LagaLaga.",
  ctaPrimary = "Explore apps",
  ctaSecondary = "View LagaLaga",
} = Astro.props;

const splitLine = (line) => ({
  initial: line.slice(0, 1),
  rest: line.slice(1),
});
---
<section id="home" class="hero relative overflow-hidden pt-28" aria-labelledby="hero-title">
  <div class="hero-bg-layer absolute inset-0 hero-grid opacity-40"></div>
  <div class="hero-mid-layer pointer-events-none absolute inset-0">
    <div class="absolute left-10 top-24 h-32 w-32 rounded-full bg-scanium-cyan/20 blur-2xl"></div>
    <div class="absolute right-16 top-40 h-40 w-40 rounded-full bg-scanium-blue/20 blur-3xl"></div>
    <div class="absolute left-1/2 top-1/3 h-56 w-56 -translate-x-1/2 rounded-full border border-scanium-cyan/30"></div>
  </div>

  <div class="relative mx-auto flex min-h-[90vh] max-w-6xl flex-col items-center gap-12 px-6 pb-24 lg:flex-row lg:items-start">
    <div class="max-w-xl">
      <p class="mb-4 text-sm uppercase tracking-[0.4em] text-scanium-cyan">{eyebrow}</p>
      <h1 id="hero-title" class="section-title text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl">
        <span class="text-scanium-yellow">{splitLine(titleLines[0]).initial}</span>{splitLine(titleLines[0]).rest}<br />
        <span class="text-scanium-yellow">{splitLine(titleLines[1]).initial}</span>{splitLine(titleLines[1]).rest}<br />
        <span class="text-scanium-yellow">{splitLine(titleLines[2]).initial}</span>{splitLine(titleLines[2]).rest}
      </h1>
      <p class="mt-6 text-lg text-text-muted">
        {description}
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="#apps" class="glow-border inline-flex items-center rounded-full bg-scanium-blue px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white shadow-lg shadow-scanium-blue/40 transition hover:-translate-y-0.5">
          {ctaPrimary}
        </a>
        <a
          href="#lagalaga"
          class="glow-border inline-flex items-center rounded-full bg-white/5 px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition hover:-translate-y-0.5 hover:bg-white/10"
        >
          {ctaSecondary}
        </a>
      </div>
    </div>

    <div class="relative w-full max-w-sm lg:mt-8">
      <div class="absolute -left-10 top-10 h-40 w-40 rounded-full bg-scanium-cyan/30 blur-3xl"></div>
      <div class="absolute -right-8 bottom-12 h-32 w-32 rounded-full bg-scanium-blue/30 blur-3xl"></div>
      <div class="floaty relative overflow-hidden rounded-[32px] border border-white/10 bg-navy-light/80 p-4 shadow-2xl shadow-black/50">
        <div class="hero-beam"></div>
        <div class="rounded-[24px] border border-white/10 bg-gradient-to-b from-white/5 to-transparent p-6">
          <div class="mb-4 text-xs uppercase tracking-[0.3em] text-text-muted">Featured app</div>
          <div class="mb-6">
            <h2 class="text-2xl font-bold text-white">LagaLaga</h2>
            <p class="mt-2 text-sm text-text-muted">Social gaming, organized.</p>
          </div>
          <div class="relative h-48 overflow-hidden rounded-2xl bg-gradient-to-br from-scanium-blue/20 via-transparent to-scanium-cyan/20">
            <div class="absolute inset-0 border border-scanium-cyan/20"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-5xl font-black tracking-tight text-white/20">LL</span>
            </div>
          </div>
          <div class="mt-4 rounded-full bg-white/5 px-4 py-2 text-center text-xs text-text-muted">
            Roblox session organizer
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
