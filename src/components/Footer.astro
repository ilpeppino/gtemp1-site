---
const {
  privacyLabel = "Privacy Policy",
  tosLabel = "Terms of Service",
  copyrightLabel = "© 2026 Gtemp1",
  basePath = "",
} = Astro.props;
---
<footer class="border-t border-white/10 bg-navy-light/60">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-6 py-10 text-center text-sm text-text-muted sm:flex-row sm:justify-between">
    <div class="flex items-center gap-3">
      <span class="font-semibold text-white">Gtemp1</span>
      <span>{copyrightLabel}</span>
    </div>
    <div class="flex items-center gap-6">
      <a href={`${basePath}/privacy`} class="text-scanium-cyan hover:text-white">{privacyLabel}</a>
      <a href={`${basePath}/tos`} class="text-scanium-cyan hover:text-white">{tosLabel}</a>
    </div>
  </div>
</footer>
