---
const {
  eyebrow = "Get in touch",
  title = "Follow our products and what comes next",
  text = "Learn more about LagaLaga, explore our work, or contact Gtemp1 for support and collaboration-related questions.",
  ctaPrimary = "View LagaLaga",
  ctaSecondary = "Contact Gtemp1",
  footer = "More products will be added as they become public.",
} = Astro.props;
---
<section id="contact" class="mx-auto max-w-6xl px-6 py-24" aria-labelledby="contact-title">
  <div class="glow-border rounded-3xl bg-gradient-to-br from-navy via-scanium-blue/50 to-navy-light p-10 text-center sm:p-14">
    <p class="text-sm uppercase tracking-[0.4em] text-scanium-cyan">{eyebrow}</p>
    <h2 id="contact-title" class="section-title mt-4 text-3xl font-semibold text-white sm:text-4xl">
      {title}
    </h2>
    <p class="mt-4 text-text-muted">{text}</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#lagalaga"
        class="glow-border inline-flex items-center rounded-full bg-scanium-blue px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white shadow-lg shadow-scanium-blue/30 transition hover:-translate-y-0.5 hover:shadow-scanium-blue/60"
      >
        {ctaPrimary}
      </a>
      <!-- PLACEHOLDER: replace with real contact email or contact page URL -->
      <a
        href="mailto:contact@gtemp1.com"
        class="glow-border inline-flex items-center rounded-full bg-white/5 px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition hover:-translate-y-0.5 hover:bg-white/10"
      >
        {ctaSecondary}
      </a>
    </div>
    <p class="mt-6 text-xs uppercase tracking-[0.25em] text-text-muted">{footer}</p>
  </div>
</section>
